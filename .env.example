# InDE v3.16 Environment Configuration
# "Production Trust"
# Copy to .env and fill in actual values

# =============================================================================
# ADMIN CONFIGURATION (v3.14 NEW)
# =============================================================================
# Email address for the admin user. This user will automatically receive
# the admin role on registration or startup. Leave empty to disable.
# The admin can access the Diagnostics Panel at /diagnostics.
INDE_ADMIN_EMAIL=

# =============================================================================
# DEMO MODE (v4.2 NEW)
# =============================================================================
# Controls availability of the Demo User account.
# ACTIVE:   Demo login is available — users can try InDE without registering.
# INACTIVE: Demo login is disabled — users must register or sign in.
# Set to INACTIVE for production beta testing to track real user participation.
DEMO_MODE=ACTIVE

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Generate these secrets using one of these methods:
#
# Python (run in terminal):
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# PowerShell:
#   [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# Linux/macOS:
#   openssl rand -hex 32
#
JWT_SECRET=generate-a-strong-random-secret-here

# Inter-Service Authentication (generate using same methods above)
SERVICE_TOKEN=generate-another-strong-secret-here

# =============================================================================
# LLM PROVIDER
# =============================================================================
ANTHROPIC_API_KEY=""

# Optional: Local LLM Fallback Model Path
FALLBACK_MODEL_PATH=

# v3.4: LLM Gateway Remote Mode (can be external host URL)
LLM_GATEWAY_URL=http://inde-llm-gateway:8080

# =============================================================================
# DOMAIN & HTTPS (v3.16)
# =============================================================================
# Domain name for HTTPS and email links
# INDE_DOMAIN=app.indeverse.com
# INDE_BASE_URL=https://app.indeverse.com

# =============================================================================
# TRANSACTIONAL EMAIL (v3.16)
# =============================================================================
# Email provider: sendgrid (recommended) or smtp
# INDE_EMAIL_PROVIDER=sendgrid

# SendGrid API key (from sendgrid.com) - required if provider is sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxx

# SMTP configuration - required if provider is smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@indeverse.com
# SMTP_FROM_NAME=InDE Innovation Platform
# SMTP_USE_TLS=true

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://inde-events:6379
REDIS_STREAM_PREFIX=inde:events:

# =============================================================================
# IKF SERVICE
# =============================================================================
IKF_SERVICE_URL=http://inde-ikf:8090
IKF_PROCESSING_MODE=local
IKF_AUTO_PREPARE=true
IKF_MAX_PENDING_REVIEWS=3

# v3.4: IKF Composition Patterns (NEW)
IKF_COMPOSITION_PATTERNS_ENABLED=true

# =============================================================================
# v3.4: CONVERGENCE PROTOCOL
# =============================================================================
# Composite threshold for convergence detection (0.0-1.0)
CONVERGENCE_THRESHOLD=0.7

# Signal weights for convergence detection (must sum to 1.0)
CONVERGENCE_SIGNAL_WEIGHTS=repetition:0.25,decision_language:0.30,summary_requests:0.15,satisfaction:0.15,time_investment:0.15

# =============================================================================
# v3.4: AUDIT PIPELINE
# =============================================================================
# Retention period for audit events (days)
AUDIT_RETENTION_DAYS=365

# Batch size for Redis -> MongoDB persistence
AUDIT_STREAM_BATCH_SIZE=100

# =============================================================================
# v3.4: IDTFS CONFIGURATION
# =============================================================================
# Maximum candidates returned per discovery search
IDTFS_MAX_CANDIDATES=20

# Hard exclusion of UNAVAILABLE innovators (never override)
IDTFS_UNAVAILABLE_HARD_EXCLUDE=true

# =============================================================================
# v3.4: ORG PORTFOLIO DASHBOARD
# =============================================================================
# Cache TTL for portfolio analytics (seconds)
ORG_PORTFOLIO_CACHE_TTL=300

# =============================================================================
# v3.15: RATE LIMITING CONFIGURATION
# =============================================================================
# Per-user coaching rate limit (requests per 60-second sliding window)
INDE_COACHING_RATE_LIMIT=30

# Per-IP authentication rate limit (attempts per window)
INDE_AUTH_RATE_LIMIT=10

# Authentication rate limit window duration (seconds)
INDE_AUTH_RATE_LIMIT_WINDOW=300

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================

# API base URL (defaults to http://localhost:8000)
  VITE_API_URL=http://localhost:8000

  # WebSocket URL (defaults to ws://localhost:8000)
  VITE_WS_URL=ws://localhost:8000
